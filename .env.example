# 智谱开放平台 API Key。也兼容 GLM_API_KEY / BIGMODEL_API_KEY。
ZHIPUAI_API_KEY=

GLM_CHAT_MODEL=glm-4.5-air
EMBEDDING_MODEL=embedding-3
